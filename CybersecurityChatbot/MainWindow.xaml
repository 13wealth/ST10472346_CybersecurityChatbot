<Window x:Class="CybersecurityChatbot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.openxmlformats.org/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CybersecurityChatbot"
        xmlns:behaviors="clr-namespace:CybersecurityChatbot.Behaviors"
        mc:Ignorable="d"
        Title="Cybersecurity Chatbot"
        Height="720"
        Width="1180"
        Background="#08111F">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#13C2C2"/>
            <Setter Property="Foreground" Value="#071018"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OpenChatButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Visibility, ElementName=ChatPanelBorder}" Value="Visible">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <SolidColorBrush x:Key="BotBubbleBrush" Color="#163045"/>
        <SolidColorBrush x:Key="UserBubbleBrush" Color="#12B886"/>
        <SolidColorBrush x:Key="SidePanelBrush" Color="#165DA7"/>

    </Window.Resources>

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.05*" MinWidth="140"/>
            <ColumnDefinition Width="1.2*" MinWidth="180"/>
            <ColumnDefinition x:Name="ChatColumn" Width="0" MinWidth="0"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Margin="0,0,14,0"
                Background="{StaticResource SidePanelBrush}"
                CornerRadius="24"
                Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="Recents"
                               Foreground="White"
                               FontSize="24"
                               FontWeight="Bold"
                               Margin="0,0,0,14"/>
                    <TextBlock Text="Your latest conversations will show here."
                               Foreground="#D9EBFF"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Margin="0,0,0,18"/>
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <ItemsControl ItemsSource="{Binding RecentChats}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1E78D6"
                                        CornerRadius="18"
                                        Padding="14"
                                        Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}"
                                                   Foreground="White"
                                                   FontSize="14"
                                                   FontWeight="Bold"/>
                                        <TextBlock Text="{Binding Preview}"
                                                   Foreground="#E8F4FF"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"
                                                   Margin="0,6,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Column="1"
                Margin="0,0,14,0"
                Background="{StaticResource SidePanelBrush}"
                CornerRadius="24"
                Padding="20">
            <Viewbox Stretch="Uniform" StretchDirection="Both">
                <Grid Width="420" Height="720">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Cybersecurity Bot"
                               Foreground="White"
                               FontSize="28"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,18"/>

                    <Border Grid.Row="1"
                            Background="#14253A"
                            CornerRadius="18"
                            Padding="16"
                            Margin="0,0,0,18">
                        <StackPanel>
                            <TextBlock Text="Assistant"
                                       Foreground="#66D9E8"
                                       FontSize="12"
                                       FontWeight="Bold"/>
                            <TextBlock Text="Ask about phishing, passwords, malware, privacy, and other common cybersecurity topics."
                                       Foreground="#D8E1EE"
                                       FontSize="13"
                                       TextWrapping="Wrap"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="2"
                          HorizontalAlignment="Center"
                          RenderTransformOrigin="0.5,0.5"
                          behaviors:SpinBehavior.EnableSpin="True"
                          behaviors:SpinBehavior.BlinkIntervalSeconds="2"
                                                    behaviors:SpinBehavior.SpinIntervalSeconds="5"
                          behaviors:SpinBehavior.SpinDurationSeconds="0.8">
                        <Grid x:Name="BotAvatarRoot">
                                                        <Ellipse Fill="{StaticResource SidePanelBrush}"
                                     Width="160"
                                                                         Height="160"
                                                                         StrokeThickness="0"/>
                            <Ellipse Fill="White"
                                     Width="18"
                                     Height="18"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Top"
                                     Margin="0,16,0,0"/>
                            <Rectangle Fill="White"
                                       Width="6"
                                       Height="24"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Top"
                                       Margin="0,28,0,0"/>
                            <Border Background="White"
                                    CornerRadius="52"
                                    Margin="28,42,28,28"/>
                            <Border Background="#1E88FF"
                                    CornerRadius="44"
                                    Margin="38,52,38,38"/>
                            <Ellipse x:Name="LeftEye"
                                     Fill="White"
                                     Width="18"
                                     Height="26"
                                     HorizontalAlignment="Left"
                                     Margin="42,64,0,0"
                                     VerticalAlignment="Top"/>
                            <Ellipse x:Name="RightEye"
                                     Fill="White"
                                     Width="18"
                                     Height="26"
                                     HorizontalAlignment="Right"
                                     Margin="0,64,42,0"
                                     VerticalAlignment="Top"/>
                            <Path x:Name="MouthPath"
                                  Stroke="White"
                                  StrokeThickness="4"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Bottom"
                                  Margin="0,0,0,28">
                                <Path.Data>
                                    <PathGeometry Figures="M 52,120 L 108,120"/>
                                </Path.Data>
                            </Path>
                        </Grid>
                    </Grid>

                    <Border Grid.Row="3"
                            Margin="0,20,0,8"
                            Background="Transparent">
                        <Viewbox Stretch="Uniform" StretchDirection="Both" MinHeight="200">
                            <TextBlock x:Name="AsciiArtBlock"
                                       Foreground="#66D9E8"
                                       FontFamily="Consolas"
                                       FontSize="18"
                                       TextAlignment="Center"
                                       TextWrapping="NoWrap"/>
                        </Viewbox>
                    </Border>

                    <Button Grid.Row="4"
                            Content="Open Chat"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Width="160"
                            Height="44"
                            Style="{StaticResource OpenChatButtonStyle}"
                            Click="OpenChatButton_Click"/>
                </Grid>
            </Viewbox>
        </Border>

        <Border Grid.Column="2"
                x:Name="ChatPanelBorder"
                Background="Transparent"
                CornerRadius="24"
                Padding="20"
                Opacity="0"
                Visibility="Collapsed">
            <Border.RenderTransform>
                <TranslateTransform X="180" x:Name="ChatSlideTransform"/>
            </Border.RenderTransform>

            <Grid Background="Transparent">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Background="Transparent"
                        CornerRadius="18"
                        Padding="16"
                        Margin="0,0,0,16">
                    <Grid>
                        <TextBlock Text="Chat"
                                   Foreground="White"
                                   FontSize="20"
                                   FontWeight="Bold"/>
                        <Button Content="Close"
                                Width="82"
                                Height="32"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Click="CloseChatButton_Click"/>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                    Background="Transparent"
                        CornerRadius="20"
                        Padding="16"
                        Margin="0,0,0,16">
                    <ScrollViewer VerticalScrollBarVisibility="Hidden"
                                  HorizontalScrollBarVisibility="Disabled"
                                  x:Name="ChatScroll">
                        <StackPanel x:Name="ChatMessagesHost"
                                    HorizontalAlignment="Stretch"
                                    Width="{Binding ViewportWidth, ElementName=ChatScroll}"/>
                    </ScrollViewer>
                </Border>

                <Border Grid.Row="2"
                        Background="Transparent"
                        CornerRadius="18"
                        Padding="14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="#0C1626"
                                CornerRadius="14"
                                Padding="10"
                                VerticalAlignment="Center"
                                Margin="0,0,12,0">
                            <TextBox x:Name="MessageInput"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Foreground="White"
                                     CaretBrush="White"
                                     FontSize="14"
                                     AcceptsReturn="False"
                                     VerticalContentAlignment="Center"
                                     KeyDown="MessageInput_KeyDown"/>
                        </Border>

                        <Button Grid.Column="1"
                                x:Name="SendButton"
                                Content="Send"
                                Width="104"
                                Height="44"
                                VerticalAlignment="Center"
                                Click="SendButton_Click"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>