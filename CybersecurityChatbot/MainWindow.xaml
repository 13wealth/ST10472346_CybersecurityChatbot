<Window x:Class="CybersecurityChatbot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.openxmlformats.org/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CybersecurityChatbot"
        xmlns:behaviors="clr-namespace:CybersecurityChatbot.Behaviors"
        mc:Ignorable="d"
        Title="Cybersecurity Chatbot"
        Height="720"
        Width="1180"
        Background="#08111F">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#13C2C2"/>
            <Setter Property="Foreground" Value="#071018"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OpenChatButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Visibility, ElementName=ChatPanelBorder}" Value="Visible">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <SolidColorBrush x:Key="BotBubbleBrush" Color="#163045"/>
        <SolidColorBrush x:Key="UserBubbleBrush" Color="#12B886"/>
        <SolidColorBrush x:Key="SidePanelBrush" Color="#165DA7"/>
        <SolidColorBrush x:Key="ChatPanelOverlayBrush" Color="#8A08111F"/>

        <DataTemplate x:Key="BotMessageTemplate">
            <Grid Margin="0,8,0,8">
                <Border HorizontalAlignment="Left"
                        Background="{StaticResource BotBubbleBrush}"
                        CornerRadius="18"
                        Padding="14,10"
                        MaxWidth="460">
                    <StackPanel>
                        <TextBlock Text="Bot"
                                   Foreground="#6EE7FF"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Margin="0,0,0,4"/>
                        <Grid>
                            <TextBlock x:Name="BotText"
                                       Text="{Binding Text}"
                                       Foreground="White"
                                       FontSize="14"
                                       TextWrapping="Wrap"/>

                            <StackPanel x:Name="TypingPanel"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Visibility="Collapsed"
                                        Margin="0,4,0,0">
                                <Ellipse x:Name="Dot1" Width="8" Height="8" Fill="White" Opacity="0" Margin="2"/>
                                <Ellipse x:Name="Dot2" Width="8" Height="8" Fill="White" Opacity="0" Margin="2"/>
                                <Ellipse x:Name="Dot3" Width="8" Height="8" Fill="White" Opacity="0" Margin="2"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding Text}" Value="__typing__">
                    <Setter TargetName="BotText" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="TypingPanel" Property="Visibility" Value="Visible"/>
                    <DataTrigger.EnterActions>
                        <BeginStoryboard x:Name="TypingStoryboard">
                            <Storyboard RepeatBehavior="Forever">
                                <DoubleAnimation Storyboard.TargetName="Dot1" Storyboard.TargetProperty="Opacity" From="0.2" To="1" Duration="0:0:0.5" AutoReverse="True" BeginTime="0:0:0" />
                                <DoubleAnimation Storyboard.TargetName="Dot2" Storyboard.TargetProperty="Opacity" From="0.2" To="1" Duration="0:0:0.5" AutoReverse="True" BeginTime="0:0:0.2" />
                                <DoubleAnimation Storyboard.TargetName="Dot3" Storyboard.TargetProperty="Opacity" From="0.2" To="1" Duration="0:0:0.5" AutoReverse="True" BeginTime="0:0:0.4" />
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <StopStoryboard BeginStoryboardName="TypingStoryboard"/>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <DataTemplate x:Key="UserMessageTemplate">
            <Grid Margin="0,8,0,8">
                <Border HorizontalAlignment="Right"
                        Background="{StaticResource UserBubbleBrush}"
                        CornerRadius="18"
                        Padding="14,10"
                        MaxWidth="460">
                    <StackPanel>
                        <TextBlock Text="You"
                                   Foreground="#EFFFFB"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Margin="0,0,0,4"
                                   HorizontalAlignment="Right"/>
                        <TextBlock Text="{Binding Text}"
                                   Foreground="#071018"
                                   FontSize="14"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>

        <local:ChatRoleTemplateSelector x:Key="ChatRoleTemplateSelector"
                                        BotTemplate="{StaticResource BotMessageTemplate}"
                                        UserTemplate="{StaticResource UserMessageTemplate}"/>

    </Window.Resources>

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.05*" MinWidth="140"/>
            <ColumnDefinition Width="1.2*" MinWidth="180"/>
            <ColumnDefinition x:Name="ChatColumn" Width="0" MinWidth="0"/>
        </Grid.ColumnDefinitions>

        <!-- ── Task Assistant Panel ── -->
        <Border Grid.Column="0"
        Margin="0,0,14,0"
        Background="{StaticResource SidePanelBrush}"
        CornerRadius="24"
        Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Title -->
                    <RowDefinition Height="Auto"/>
                    <!-- Input fields -->
                    <RowDefinition Height="Auto"/>
                    <!-- Add button -->
                    <RowDefinition Height="*"/>
                    <!-- Task list -->
                    <RowDefinition Height="Auto"/>
                    <!-- Action buttons -->
                </Grid.RowDefinitions>

                <!-- Panel Title -->
                <TextBlock Grid.Row="0"
                   Text="📋 Task Assistant"
                   Foreground="White"
                   FontSize="22"
                   FontWeight="Bold"
                   Margin="0,0,0,16"/>

                <!-- Input Fields -->
                <StackPanel Grid.Row="1" Margin="0,0,0,6">

                    <!-- Task Title -->
                    <TextBlock Text="Task Title"
                       Foreground="#66D9E8"
                       FontSize="12"
                       FontWeight="Bold"
                       Margin="0,0,0,4"/>
                    <Border Background="#14253A"
                    CornerRadius="10"
                    Padding="10,6"
                    Margin="0,0,0,10">
                        <TextBox x:Name="TaskTitleInput"
                         BorderThickness="0"
                         Background="Transparent"
                         Foreground="White"
                         CaretBrush="White"
                         FontSize="13"/>
                    </Border>

                    <!-- Task Description -->
                    <TextBlock Text="Description"
                       Foreground="#66D9E8"
                       FontSize="12"
                       FontWeight="Bold"
                       Margin="0,0,0,4"/>
                    <Border Background="#14253A"
                    CornerRadius="10"
                    Padding="10,6"
                    Margin="0,0,0,10">
                        <TextBox x:Name="TaskDescriptionInput"
                         BorderThickness="0"
                         Background="Transparent"
                         Foreground="White"
                         CaretBrush="White"
                         FontSize="13"
                         Height="55"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"/>
                    </Border>

                    <!-- Reminder -->
                    <TextBlock Text="Reminder (optional)"
                       Foreground="#66D9E8"
                       FontSize="12"
                       FontWeight="Bold"
                       Margin="0,0,0,4"/>
                    <Border Background="#14253A"
                    CornerRadius="10"
                    Padding="10,6"
                    Margin="0,0,0,2">
                        <TextBox x:Name="TaskReminderInput"
                         BorderThickness="0"
                         Background="Transparent"
                         Foreground="#AAAAAA"
                         CaretBrush="White"
                         FontSize="13"/>
                    </Border>

                    <!-- Hint text under reminder -->
                    <TextBlock Text="e.g. Remind me in 7 days"
                       Foreground="#5A7A9A"
                       FontSize="11"
                       Margin="4,2,0,0"/>
                </StackPanel>

                <!-- Add Task Button -->
                <Button Grid.Row="2"
                x:Name="AddTaskButton"
                Content="＋ Add Task"
                Height="38"
                Margin="0,10,0,12"
                Click="AddTaskButton_Click"/>

                <!-- Task List -->
                <Border Grid.Row="3"
                Background="#0C1A2A"
                CornerRadius="14"
                Padding="8"
                Margin="0,0,0,10">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ListBox x:Name="TaskListBox"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="White"
                         FontSize="12"
                         SelectionMode="Single">

                            <!-- How each task looks in the list -->
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8,6"
                                    Margin="0,3"
                                    Background="#14253A"
                                    CornerRadius="10">
                                        <StackPanel>

                                            <!-- Title row with status icon -->
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0"
                                                   Text="{Binding Title}"
                                                   Foreground="White"
                                                   FontWeight="Bold"
                                                   FontSize="13"
                                                   TextWrapping="Wrap"/>

                                                <!-- Shows tick if complete, square if pending -->
                                                <TextBlock Grid.Column="1"
                                                   FontSize="13"
                                                   Margin="6,0,0,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="🔲"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsComplete}" Value="True">
                                                                    <Setter Property="Text" Value="✅"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>

                                            <!-- Description -->
                                            <TextBlock Text="{Binding Description}"
                                               Foreground="#A0B8D0"
                                               FontSize="11"
                                               TextWrapping="Wrap"
                                               Margin="0,3,0,0"/>

                                            <!-- Reminder -->
                                            <TextBlock Foreground="#66D9E8"
                                               FontSize="11"
                                               Margin="0,2,0,0">
                                        <Run Text="⏰ "/>
                                        <Run Text="{Binding Reminder}"/>
                                            </TextBlock>

                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>

                            <!-- Removes the default blue highlight when a task is selected -->
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>

                        </ListBox>
                    </ScrollViewer>
                </Border>

                <!-- Mark Complete and Delete Buttons side by side -->
                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                    x:Name="MarkCompleteButton"
                    Content="✅ Complete"
                    Height="36"
                    Click="MarkCompleteButton_Click"/>

                    <Button Grid.Column="2"
                    x:Name="DeleteTaskButton"
                    Content="🗑️ Delete"
                    Height="36"
                    Background="#C0392B"
                    Click="DeleteTaskButton_Click"/>
                </Grid>

            </Grid>
        </Border>

        <Border Grid.Column="1"
                Margin="0,0,14,0"
                Background="{StaticResource SidePanelBrush}"
                CornerRadius="24"
                Padding="20">
            <Viewbox Stretch="Uniform" StretchDirection="Both">
                <Grid Width="420" Height="720">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Cybersecurity Bot"
                               Foreground="White"
                               FontSize="28"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,18"/>

                    <Border Grid.Row="1"
                            Background="#14253A"
                            CornerRadius="18"
                            Padding="16"
                            Margin="0,0,0,18">
                        <StackPanel>
                            <TextBlock Text="Assistant"
                                       Foreground="#66D9E8"
                                       FontSize="12"
                                       FontWeight="Bold"/>
                            <TextBlock Text="Ask about phishing, passwords, malware, privacy, and other common cybersecurity topics."
                                       Foreground="#D8E1EE"
                                       FontSize="13"
                                       TextWrapping="Wrap"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="2"
                          HorizontalAlignment="Center"
                          RenderTransformOrigin="0.5,0.5"
                          behaviors:SpinBehavior.EnableSpin="True"
                          behaviors:SpinBehavior.BlinkIntervalSeconds="2"
                                                    behaviors:SpinBehavior.SpinIntervalSeconds="5"
                          behaviors:SpinBehavior.SpinDurationSeconds="0.8">
                        <Grid x:Name="BotAvatarRoot">
                                                        <Ellipse Fill="{StaticResource SidePanelBrush}"
                                     Width="160"
                                                                         Height="160"
                                                                         StrokeThickness="0"/>
                            <Ellipse Fill="White"
                                     Width="18"
                                     Height="18"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Top"
                                     Margin="0,16,0,0"/>
                            <Rectangle Fill="White"
                                       Width="6"
                                       Height="24"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Top"
                                       Margin="0,28,0,0"/>
                            <Border Background="White"
                                    CornerRadius="52"
                                    Margin="28,42,28,28"/>
                            <Border Background="#1E88FF"
                                    CornerRadius="44"
                                    Margin="38,52,38,38"/>
                            <Ellipse x:Name="LeftEye"
                                     Fill="White"
                                     Width="18"
                                     Height="26"
                                     HorizontalAlignment="Left"
                                     Margin="42,64,0,0"
                                     VerticalAlignment="Top"/>
                            <Ellipse x:Name="RightEye"
                                     Fill="White"
                                     Width="18"
                                     Height="26"
                                     HorizontalAlignment="Right"
                                     Margin="0,64,42,0"
                                     VerticalAlignment="Top"/>
                            <Path x:Name="MouthPath"
                                  Stroke="White"
                                  StrokeThickness="4"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Bottom"
                                  Margin="0,0,0,28">
                                <Path.Data>
                                    <PathGeometry Figures="M 52,120 L 108,120"/>
                                </Path.Data>
                            </Path>
                        </Grid>
                    </Grid>

                    <Border Grid.Row="3"
                            Margin="0,20,0,8"
                            Background="Transparent">
                        <Viewbox Stretch="Uniform" StretchDirection="Both" MinHeight="200">
                            <TextBlock x:Name="AsciiArtBlock"
                                       Foreground="#66D9E8"
                                       FontFamily="Consolas"
                                       FontSize="18"
                                       TextAlignment="Center"
                                       TextWrapping="NoWrap"/>
                        </Viewbox>
                    </Border>

                    <Button Grid.Row="4"
                            Content="Open Chat"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Width="160"
                            Height="44"
                            Style="{StaticResource OpenChatButtonStyle}"
                            Click="OpenChatButton_Click"/>
                </Grid>
            </Viewbox>
        </Border>

        <Border Grid.Column="2"
                x:Name="ChatPanelBorder"
                Background="#0C1626"
                CornerRadius="24"
                Padding="20"
                Opacity="0"
                Visibility="Collapsed">
            <Border.RenderTransform>
                <TranslateTransform X="180" x:Name="ChatSlideTransform"/>
            </Border.RenderTransform>

            <Grid Background="{StaticResource ChatPanelOverlayBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Background="Transparent"
                        CornerRadius="18"
                        Padding="16"
                        Margin="0,0,0,16">
                    <Grid>
                        <TextBlock Text="Chat"
                                   Foreground="White"
                                   FontSize="20"
                                   FontWeight="Bold"/>
                        <Button Content="Close"
                                Width="82"
                                Height="32"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Click="CloseChatButton_Click"/>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                    Background="Transparent"
                        CornerRadius="20"
                        Padding="16"
                        Margin="0,0,0,16">
                    <ScrollViewer VerticalScrollBarVisibility="Hidden"
                                  HorizontalScrollBarVisibility="Disabled"
                                  x:Name="ChatScroll">
                        <ItemsControl x:Name="ChatMessagesList"
                                      ItemsSource="{Binding Messages}"
                                      ItemTemplateSelector="{StaticResource ChatRoleTemplateSelector}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel HorizontalAlignment="Stretch"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <Border Grid.Row="2"
                        Background="Transparent"
                        CornerRadius="18"
                        Padding="14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="#0C1626"
                                CornerRadius="14"
                                Padding="10"
                                VerticalAlignment="Center"
                                Margin="0,0,12,0">
                            <TextBox x:Name="MessageInput"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Foreground="White"
                                     CaretBrush="White"
                                     FontSize="14"
                                     AcceptsReturn="False"
                                     VerticalContentAlignment="Center"
                                     KeyDown="MessageInput_KeyDown"/>
                        </Border>

                        <Button Grid.Column="1"
                                x:Name="SendButton"
                                Content="Send"
                                Width="104"
                                Height="44"
                                VerticalAlignment="Center"
                                Click="SendButton_Click"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>