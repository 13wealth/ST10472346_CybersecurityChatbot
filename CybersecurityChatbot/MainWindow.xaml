<Window x:Class="CybersecurityChatbot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CybersecurityChatbot"
        mc:Ignorable="d"
        Title="Cybersecurity Chatbot"
        Height="600"
        Width="1000"
        
        Background="#0B132B">

    <Window.Resources>
        <Style TargetType="Button">                                                                 <!-- Global button style for a modern look -->          
            <Setter Property="Background"
                    Value="#00FFFF"/>                                                             <!-- Applies this styleto all Button controls unless overridden -->
            <Setter Property="Foreground"
                    Value="Black"/>
            <Setter Property="FontWeight"
                    Value="Bold"/>
            <Setter Property="BorderThickness"
                    Value="0"/>
            <Setter Property="Padding"
                    Value="10"/>
            <Setter Property="Cursor"
                    Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    
                    <ControlTemplate TargetType="Button">                                           <!-- Defines a custom ControlTemplate that replaces the default button UI -->         
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="12">                                                  <!-- Rounded corners and background color from the style -->                           
                            <ContentPresenter HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>                                    <!-- Displays the button's content/text centered within the border -->                             
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>                                                                    <!-- Defines the columns in the grid -->            
            <ColumnDefinition Width="200"/>                                                         <!-- Left sidebar for recents -->          
            <ColumnDefinition Width="*"/>                                                           <!-- Main area for bot avatar and ASCII art -->           
            <ColumnDefinition x:Name="BubbleColumn" Width="0"/>
            <!-- Right column for chat bubble, Width="0" means it's hidden at startup -->
        </Grid.ColumnDefinitions>

<!-- LEFT SIDE BAR FOR RECENT CHATS -->
        
        <Border Grid.Column="0"
                BorderBrush="#1C2541"
                BorderThickness="0"
                Margin="5"
                Background="#1C2541"
                CornerRadius="20"
        >
            <!-- Container for the recent chats sidebar with styling -->
            <StackPanel Margin="10">
                <!-- creates a simple vertical layout container -->
                <TextBlock Text="Recents"
                        Foreground="#00FFFF"
                        FontSize="18"
                        FontWeight="Bold"
                        Margin="0,0,0,10"/>
                <TextBlock Text="Chat 1: Malware..."
                        Foreground="White"
                        Margin="0,5,0,0"/>
                <TextBlock Text="Chat 2: Phishing..."
                        Foreground="White"
                        Margin="0,5,0,0"/>
            </StackPanel>
        </Border>
        
<!-- CENTER AREA FOR BOT AVATAR AND ASCII ART -->

        <Border Grid.Column="1"
                BorderBrush="#1C2541"
                BorderThickness="0"
                Margin="5"
                Background="#1C2541"
                CornerRadius="20"
        >                                                                               <!-- Container for the ASCII section and avatar -->
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
            >                                                                           <!--- Create a vertical layout for the ASCII art and avatar -->
                <TextBlock Text="Cybersecurity Bot"
                           Foreground="#00FFFF"
                           FontSize="26"
                        FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"
                />                                                                      <!--- Heading block -->
                <Viewbox Grid.Column="1"
                         Stretch="Uniform"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                >                                                                       <!-- Wraps the ASCII art for a responsive display -->
                    <TextBlock x:Name="AsciiArtBlock"
                               Foreground="#00FFFF"
                               FontFamily="Consolas"
                               FontSize="14"
                               TextAlignment="Center"
                />                                                                      <!--- ASCII Art Block -->
                </Viewbox>
            </StackPanel>
        </Border>

<!-- RIGHT SIDE FOR CHAT BUBBLE -->

        <Border x:Name="ChatBubble"
                Grid.Column="2"
                Margin="5"
                Background="White"
                BorderBrush="#1C2541"
                BorderThickness="0"
                CornerRadius="20"
                Visibility="Collapsed">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>                                        <!-- Sets the row height to fill available space -->
                </Grid.RowDefinitions>

                <Button x:Name="CloseChatButton"
                        Width="40"
                        Height="40"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,-15,-15,0"
                        Padding="0"
                        BorderThickness="0"
                        Background="Transparent"
                        Foreground="White"
                        FontSize="12"
                        Content="Close"
                        Click="CloseChatButton_Click"
                        Panel.ZIndex="50"
                        Cursor="Hand"
                >
                    <Button.Style>
                        <!-- Custom style to make the close button circular with blue bg and close as content -->
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <!-- Declares that the default style is overridden -->
                                <Setter.Value>
                                    <!-- Override the default button styling -->
                                    <ControlTemplate TargetType="Button">
                                        <!-- Creates a circular button template -->
                                        <Grid>
                                            <!-- Sets a layout container and lets you lay elements ontop of each other -->
                                            <Ellipse Fill="#1E88FF"/>
                                            <ContentPresenter
                                                HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                            />
                                            <!-- Displays the content inside the button -->
                                        </Grid>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <ScrollViewer x:Name="ChatScroll"
                              VerticalScrollBarVisibility="Auto"
                              Grid.Row="0"
                >                                                                       <!-- Allows the chat history to be scrollable when it exceeds the visible area -->
                    
                    <TextBox x:Name="ChatHistoryBox"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             BorderThickness="0"
                             Background="Transparent"
                             Foreground="Black"
                             FontSize="14"
                             Padding="5"
                    />
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Text Input Box positioned above bot avatar -->

        <Grid Grid.Column="2"
              HorizontalAlignment="Center"
              VerticalAlignment="Bottom"
              Height="112"
              Width="360"
              Margin="0,0,0,96"
              Panel.ZIndex="40"
              x:Name="InputPanel"
              Visibility="Collapsed"
        >
            <StackPanel HorizontalAlignment="Stretch"
                        VerticalAlignment="Center"
            >
                <Border BorderBrush="#3A506B"
                        BorderThickness="1"
                        CornerRadius="8"
                        Background="White"
                        Padding="6"
                        Margin="20,0,20,10"
                >
                    <TextBox x:Name="MessageInput"
                             BorderThickness="0"
                             VerticalContentAlignment="Center"
                             Padding="6"
                             Background="Transparent"
                             Foreground="Black"
                             FontSize="13"
                             KeyDown="MessageInput_KeyDown"
                    />
                </Border>

                <Button x:Name="SendButton"
                        Content="Send"
                        Click="SendButton_Click"
                        HorizontalAlignment="Center"
                        Width="72"
                        Height="34"
                        Cursor="Hand"
                >
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#00FFFF"/>
                            <Setter Property="Foreground" Value="Black"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="8,4"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="6"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>

        <!-- BOT AVATAR -->

        <Grid Grid.ColumnSpan="3"
              HorizontalAlignment="Right"
              VerticalAlignment="Bottom"
              Height="90"
                Width="90"
              Margin="0,0,15,15"
              Panel.ZIndex="10"
              MouseEnter="Bot_MouseEnter"
        >
            <Border Background="#1E88FF"
                    CornerRadius="20"
            />
            <Ellipse Fill="White"
                    Width="14"
                    Height="14"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Margin="0,5,0,0"
            />
            <Rectangle Fill="White"
                    Width="4"
                    Height="14"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Margin="0,15,0,0"
            />
            <Border Background="White"
                    CornerRadius="26"
                    Margin="14,20,14,14"/>
            <Border Background="#1E88FF"
                    CornerRadius="22"
                    Margin="20,26,20,18"
            />
            <Ellipse x:Name="LeftEye"
                    Fill="White"
                    Width="10"
                    Height="18"
                    HorizontalAlignment="Left"
                    Margin="25,34,0,0"
                    VerticalAlignment="Top"
            />
            <Ellipse x:Name="RightEye"
                    Fill="White"
                    Width="10"
                    Height="18"
                    HorizontalAlignment="Right"
                    Margin="0,34,25,0"
                    VerticalAlignment="Top"
            />
            <Path x:Name="MouthPath"
                    Stroke="White"
                    StrokeThickness="3"
                    StrokeStartLineCap="Round"
                    StrokeEndLineCap="Round"
            >
                <Path.Data>
                    <PathGeometry Figures="M 33,59 L 57,59"/>
                </Path.Data>
            </Path>

            <Grid.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever">
                            <DoubleAnimation Storyboard.TargetName="LeftEye"
                                    Storyboard.TargetProperty="Height"
                                    From="20"
                                    To="2"
                                    Duration="0:0:0.1"
                                    AutoReverse="True"
                                    BeginTime="0:0:3"/>
                            <DoubleAnimation Storyboard.TargetName="RightEye"
                                    Storyboard.TargetProperty="Height"
                                    From="20"
                                    To="2"
                                    Duration="0:0:0.1"
                                    AutoReverse="True"
                                    BeginTime="0:0:3"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever"
                                BeginTime="0:0:4">
                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="MouthPath"
                                    Storyboard.TargetProperty="Data">
                                <DiscreteObjectKeyFrame KeyTime="0:0:0">
                                    <DiscreteObjectKeyFrame.Value>
                                        <PathGeometry Figures="M 33,59 Q 45,65 57,59"/>
                                    </DiscreteObjectKeyFrame.Value>
                                </DiscreteObjectKeyFrame>
                                <DiscreteObjectKeyFrame KeyTime="0:0:2">
                                    <DiscreteObjectKeyFrame.Value>
                                        <PathGeometry Figures="M 33,59 L 57,59"/>
                                    </DiscreteObjectKeyFrame.Value>
                                </DiscreteObjectKeyFrame>
                                <DiscreteObjectKeyFrame KeyTime="0:0:4">
                                    <DiscreteObjectKeyFrame.Value>
                                        <PathGeometry Figures="M 33,59 L 57,59"/>
                                    </DiscreteObjectKeyFrame.Value>
                                </DiscreteObjectKeyFrame>
                            </ObjectAnimationUsingKeyFrames>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Grid.Triggers>
        </Grid>
    </Grid>
</Window>